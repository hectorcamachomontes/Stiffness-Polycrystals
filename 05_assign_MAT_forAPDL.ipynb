import re

# Open the input file for reading
with open("file.ans", "r") as infile:
    lines = infile.readlines()

modified_lines = []

# Regular expression to match lines like "TYPE,<number>"
pattern = re.compile(r'^\s*TYPE,\s*(\d+)\s*$')

# Process each line
for line in lines:
    modified_lines.append(line)
    # Check if the line matches "TYPE,<number>"
    match = pattern.match(line)
    if match:
        number = match.group(1)
        # Insert "MAT,<number>" right after the TYPE line
        modified_lines.append(f"MAT,{number}\n")

# Write the modified lines to a new file
with open("apdl_modified.txt", "w") as outfile:
    outfile.writelines(modified_lines)

print("Processing complete. Modified file saved as apdl_modified.txt")
